# deps
# Node.js dependencies
node_modules
.pnpm-store
.pnpm-debug.log

# Keep pnpm-lock.yaml
!pnpm-lock.yaml

# build
dist/
bazel-*
user.bazelrc
build/
out/
storybook-static/
target/

# ignore README for publishing
codex-cli/README.md

# ignore Nix derivation results
result

# editor
.vscode/
.idea/
.history/
.zed/
*.swp
*~

# cli tools
CLAUDE.md
.claude/
AGENTS.override.md

# caches
.cache/
.turbo/
.parcel-cache/
.eslintcache
.nyc_output/
.jest/
*.tsbuildinfo

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env
.env*
!.env.example
.venv/

# package
*.tgz

# ci
.vercel/
.netlify/

# patches
apply_patch/

# coverage
coverage/

# personal files
personal/
external/
configure-deepseek.ps1

# Local agent / IDE (do not publish)
.cursor/
agent-transcripts/

# Local Codex config copies (never commit API keys)
.codexStudy/
.codex/

# CodexStudy desktop (build output; sources under desktop/ are tracked)
desktop/dist/
desktop/vite-dev.log
desktop/src-tauri/target/
desktop/src-tauri/gen/
desktop/src-tauri/binaries/*
!desktop/src-tauri/binaries/.gitignore

# Debug symbols / accidental copies outside target/
*.pdb
desktop/src-tauri/target/release/nsis-output.exe

# os
.DS_Store
Thumbs.db
.Spotlight-V100/

# keep desktop app source assets visible to git
!desktop/src-tauri/icons/
!desktop/src-tauri/icons/**

# Unwanted package managers
.yarn/
yarn.lock

# release
package.json-e
session.ts-e
CHANGELOG.ignore.md

# nix related
.direnv
.envrc

# Python bytecode files
__pycache__/
*.pyc
