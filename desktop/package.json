{
    "name":  "codexstudy-desktop",
    "private":  true,
    "version":  "0.7.68",
    "type":  "module",
    "scripts":  {
                    "generate:app-icon":  "node scripts/generate-app-icon.mjs",
                    "sync:material-icons":  "node scripts/sync-material-icons.mjs",
                    "prepare:bundled-codex":  "node scripts/prepare-bundled-codex.mjs",
                    "prepare:bundled-codex:force":  "node scripts/prepare-bundled-codex.mjs --force",
                    "package:cli:win":  "node scripts/prepare-bundled-codex.mjs --release && node scripts/package-codexstudy-cli.mjs",
                    "prepare:bundled-computer-use":  "node scripts/prepare-bundled-computer-use.mjs",
                    "postinstall":  "node scripts/sync-material-icons.mjs",
                    "predev":  "node scripts/sync-material-icons.mjs",
                    "dev":  "vite",
                    "prebuild":  "node scripts/sync-material-icons.mjs",
                    "build":  "tsc \u0026\u0026 vite build",
                    "dev:tauri-bootstrap":  "node scripts/sync-material-icons.mjs \u0026\u0026 node scripts/prepare-bundled-codex.mjs --debug \u0026\u0026 node scripts/prepare-bundled-computer-use.mjs \u0026\u0026 vite",
                    "build:tauri-bootstrap":  "node scripts/sync-material-icons.mjs \u0026\u0026 node scripts/prepare-bundled-codex.mjs --release \u0026\u0026 node scripts/prepare-bundled-computer-use.mjs --release \u0026\u0026 tsc \u0026\u0026 vite build",
                    "build:appimage":  "NO_STRIP=1 tauri build --bundles appimage",
                    "doctor":  "sh scripts/doctor.sh",
                    "doctor:strict":  "sh scripts/doctor.sh --strict",
                    "doctor:win":  "node scripts/doctor.mjs --strict",
                    "lint":  "eslint . --ext .ts,.tsx",
                    "lint:ds":  "eslint . --ext .ts,.tsx",
                    "codemod:modal-shell":  "node scripts/codemods/modal-shell-codemod.mjs",
                    "codemod:panel-shell":  "node scripts/codemods/panel-shell-codemod.mjs",
                    "codemod:toast-shell":  "node scripts/codemods/toast-shell-codemod.mjs",
                    "codemod:ds:dry":  "node scripts/codemods/modal-shell-codemod.mjs --dry-run \u0026\u0026 node scripts/codemods/panel-shell-codemod.mjs --dry-run \u0026\u0026 node scripts/codemods/toast-shell-codemod.mjs --dry-run",
                    "codemod:ds":  "node scripts/codemods/modal-shell-codemod.mjs \u0026\u0026 node scripts/codemods/panel-shell-codemod.mjs \u0026\u0026 node scripts/codemods/toast-shell-codemod.mjs",
                    "test":  "vitest run",
                    "test:watch":  "vitest",
                    "typecheck":  "tsc --noEmit",
                    "preview":  "vite preview",
                    "tauri":  "tauri",
                    "pretauri:dev":  "node scripts/sync-material-icons.mjs",
                    "tauri:dev":  "sh scripts/doctor.sh --strict \u0026\u0026 tauri dev",
                    "pretauri:build":  "node scripts/sync-material-icons.mjs",
                    "tauri:build":  "sh scripts/doctor.sh --strict \u0026\u0026 tauri build",
                    "pretauri:dev:win":  "node scripts/sync-material-icons.mjs",
                    "tauri:dev:win":  "node scripts/doctor.mjs --strict \u0026\u0026 tauri dev --config src-tauri/tauri.windows.conf.json",
                    "pretauri:build:win":  "node scripts/sync-material-icons.mjs",
                    "tauri:build:win":  "node scripts/doctor.mjs --strict \u0026\u0026 tauri build --config src-tauri/tauri.windows.conf.json",
                    "tauri:build:nsis:win":  "node scripts/doctor.mjs --strict \u0026\u0026 tauri build --bundles nsis --config src-tauri/tauri.windows.conf.json",
                    "tauri:bundle-only:nsis:win":  "node scripts/doctor.mjs --strict \u0026\u0026 tauri build --bundles nsis --config src-tauri/tauri.windows.conf.json --config src-tauri/tauri.bundle-only.conf.json",
                    "tauri:build:msi:win":  "node scripts/doctor.mjs --strict \u0026\u0026 tauri build --bundles msi --config src-tauri/tauri.windows.conf.json"
                },
    "dependencies":  {
                         "@pierre/diffs":  "^1.0.6",
                         "@sentry/react":  "^10.36.0",
                         "@tanstack/react-virtual":  "^3.13.18",
                         "@tauri-apps/api":  "^2.10.1",
                         "@tauri-apps/plugin-dialog":  "^2.6.0",
                         "@tauri-apps/plugin-notification":  "^2.3.3",
                         "@tauri-apps/plugin-opener":  "^2.5.3",
                         "@tauri-apps/plugin-process":  "^2.3.1",
                         "@tauri-apps/plugin-updater":  "^2.10.0",
                         "@xterm/addon-fit":  "^0.10.0",
                         "@xterm/xterm":  "^5.5.0",
                         "lucide-react":  "^0.562.0",
                         "prismjs":  "^1.30.0",
                         "react":  "^19.1.0",
                         "react-dom":  "^19.1.0",
                         "react-markdown":  "^10.1.0",
                         "remark-gfm":  "^4.0.1",
                         "tauri-plugin-liquid-glass-api":  "^0.1.6",
                         "vscode-material-icons":  "^0.1.1"
                     },
    "devDependencies":  {
                            "@tauri-apps/cli":  "^2.10.1",
                            "@testing-library/react":  "^16.3.2",
                            "@types/prismjs":  "^1.26.5",
                            "@types/react":  "^19.1.8",
                            "@types/react-dom":  "^19.1.6",
                            "@typescript-eslint/eslint-plugin":  "^7.18.0",
                            "@typescript-eslint/parser":  "^7.18.0",
                            "eslint":  "^8.57.0",
                            "eslint-plugin-react":  "^7.36.1",
                            "eslint-plugin-react-hooks":  "^4.6.2",
                            "jsdom":  "^27.0.1",
                            "typescript":  "~5.8.3",
                            "vite":  "^7.0.4",
                            "vitest":  "^3.2.4"
                        }
}
